import json
import os
import uuid
from datetime import datetime

BOOKINGS_FILE = "bookings.json"

# --- Equipment List ---
equipment_list = [
    "Laptop A", "Laptop B", "Projector 1", "Projector 2", "DSLR Camera 1",
    "DSLR Camera 2", "Tripod Stand", "Audio Recorder", "Microphone Kit",
    "Digital Tablet A", "Digital Tablet B", "VR Headset", "3D Printer",
    "Scientific Calculator A", "Scientific Calculator B", "Graphing Tablet",
    "LED Light Panel", "Portable Monitor", "Bluetooth Keyboard",
    "Portable Hard Drive"
]

# --- Loading and Saving Data Functions ---
def load_bookings():
    if not os.path.exists(BOOKINGS_FILE):
        return []
    with open(BOOKINGS_FILE, "r") as f:
        return json.load(f)

def save_bookings(bookings):
    with open(BOOKINGS_FILE, "w") as f:
        json.dump(bookings, f, indent=4)

# --- Menu Functions ---
def view_equipment():
    print("\n--- Available Equipment ---")
    for i, item in enumerate(equipment_list, start=1):
        print(f"{i}. {item}")

# --- Booking Function ---
def book_equipment(bookings):
    print("\n--- Book Equipment ---")
    view_equipment()

    try:
        choice = int(input("\nSelect equipment number to book: "))
    except ValueError:
        print("Invalid input. Please enter a number.")
        return

    if choice < 1 or choice > len(equipment_list):
        print("Invalid selection.")
        return

    selected_item = equipment_list[choice - 1]

    first = input("First Name: ").strip()
    last = input("Last Name: ").strip()

    # Automatically generate booking ID
    booking_id = "BK" + str(uuid.uuid4())[:8].upper()

    # Validate booking date
    while True:
        date_booked = input("Date of Booking (YYYY-MM-DD): ").strip()
        try:
            datetime.strptime(date_booked, "%Y-%m-%d")
            break
        except ValueError:
            print("Invalid date format. Please enter the date as YYYY-MM-DD.")

    # Validate expected return date
    while True:
        expected_return = input("Expected Return Date (YYYY-MM-DD): ").strip()
        try:
            booked_date_obj = datetime.strptime(date_booked, "%Y-%m-%d")
            return_date_obj = datetime.strptime(expected_return, "%Y-%m-%d")

            if return_date_obj < booked_date_obj:
                print("Expected return date cannot be before booking date.")
            else:
                break
        except ValueError:
            print("Invalid date format. Please enter the date as YYYY-MM-DD.")

    booking = {
        "first_name": first,
        "last_name": last,
        "booking_id": booking_id,
        "equipment": selected_item,
        "date_booked": date_booked,
        "expected_return": expected_return,
        "returned": False
    }

    bookings.append(booking)
    save_bookings(bookings)

    print("\nEquipment booked successfully!")
    print(f"Generated Booking ID: {booking_id}")

# --- View Bookings Function ---
def view_bookings(bookings):
    print("\n--- All Bookings ---")
    if not bookings:
        print("No bookings found.")
        return

    for b in bookings:
        status = "Returned" if b["returned"] else "Not Returned"
        print(f"""
Booking ID: {b['booking_id']}
Name: {b['first_name']} {b['last_name']}
Equipment: {b['equipment']}
Booked On: {b['date_booked']}
Expected Return: {b['expected_return']}
Status: {status}
""")

# --- Return Equipment Function ---
def return_booking(bookings):
    print("\n--- Return Equipment ---")
    booking_id = input("Enter Booking ID to return: ").strip()

    for b in bookings:
        if b["booking_id"] == booking_id:
            if b["returned"]:
                print("This booking has already been returned.")
                return
            b["returned"] = True
            save_bookings(bookings)
            print("Equipment successfully marked as returned.")
            return

    print("Booking ID not found.")

# --- View Late Returns Function ---
def view_late_returns(bookings):
    print("\n--- Late Returns ---")
    today = datetime.today().date()
    found = False

    for b in bookings:
        if not b["returned"]:
            try:
                expected = datetime.strptime(b["expected_return"], "%Y-%m-%d").date()
            except ValueError:
                print(f"Invalid date format in booking ID {b['booking_id']}")
                continue

            if expected < today:
                found = True
                print(f"""
*** LATE RETURN ***
Booking ID: {b['booking_id']}
Name: {b['first_name']} {b['last_name']}
Equipment: {b['equipment']}
Expected Return: {b['expected_return']}
---------------------------
""")

    if not found:
        print("No late returns found.")

# --- Main Program ---
def main():
    bookings = load_bookings()

    while True:
        print("\n====== RESTART Academic Booking System ======")
        print("1. View Equipment")
        print("2. Book Equipment")
        print("3. View All Bookings")
        print("4. Return Equipment")
        print("5. View Late Returns")
        print("6. Exit")

        choice = input("Select an option (1-6): ").strip()

        if choice == "1":
            view_equipment()
        elif choice == "2":
            book_equipment(bookings)
        elif choice == "3":
            view_bookings(bookings)
        elif choice == "4":
            return_booking(bookings)
        elif choice == "5":
            view_late_returns(bookings)
        elif choice == "6":
            print("Exiting system. Goodbye!")
            break
        else:
            print("Invalid choice. Try again.")

if __name__ == "__main__":
    main()
